# Redmine
REDMINE_BASE_URL=https://example.com/redmine
REDMINE_API_KEY=__REPLACE__
REDMINE_PROJECT_ID=802
POLL_INTERVAL_SECONDS=120
ISSUE_FETCH_LIMIT=50

# Teams
TEAMS_MODE=bot  # bot|graph
TEAMS_TARGET=chat  # chat|channel

# Bot (推奨)
BOT_APP_ID=__REPLACE__
BOT_APP_PASSWORD=__REPLACE__
BOT_ENDPOINT_URL=https://<public-endpoint>/api/messages
TEAMS_CHAT_ID=__REPLACE__

# Bot サーバー受信ポート
BOT_SERVER_HOST=0.0.0.0
BOT_SERVER_PORT=3978

# Graph (代替: TEAMS_MODE=graph の場合)
MS_TENANT_ID=__REPLACE__
MS_CLIENT_ID=__REPLACE__
MS_CLIENT_SECRET=__REPLACE__

# Box
BOX_MODE=api  # direct|api
BOX_ACCESS_TOKEN=__REPLACE__
BOX_SHARED_LINK_PASSWORD=

# Local
WORK_ROOT=/tmp/redmine_auto

# SQLite DB
DB_PATH=state.db

# Optional
GOOGLE_UPLOAD_MODE=none
